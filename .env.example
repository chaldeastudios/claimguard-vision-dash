# service_role key (Supabase dashboard -> Project Settings -> API -> service_role).
# Backend-only. Bypasses RLS -- never expose this to the frontend/dashboard env,
# never commit it. Used by openimis-be-fraud_py's server-to-server sync, which
# writes without an authenticated browser session (RLS would reject the anon
# key above for those writes).
SUPABASE_SERVICE_ROLE_KEY=""

GEMINI_API_KEY=""

# openIMIS service account used by the dashboard's server-side GraphQL client
# (src/lib/openimis.server.ts) to fetch live claims from the local Docker
# stack's openIMIS backend. Use a working non-admin account (e.g. one of the
# demo dataset users) -- see README's "Known Limitations" for the Admin
# account login issue.
OPENIMIS_USERNAME=""
OPENIMIS_PASSWORD=""
