# There's no more Supabase Auth or browser-side Supabase client (see
# src/lib/auth-session.server.ts) -- ClaimGuard only ever talks to Supabase
# server-side, via the service-role client, for its own data (claim_risk_analysis,
# organizations, claim_insurer_assignment). Never expose SUPABASE_SERVICE_ROLE_KEY
# to the client bundle or commit it.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Encrypts the sign-in session cookie (see src/lib/auth-session.server.ts).
# Any string of 32+ characters works; there's a dev fallback if unset, so
# this is only worth setting for a real deployment.
SESSION_SECRET=""

GEMINI_API_KEY=""

# The dashboard's own dev-server port (see vite.config.ts) -- defaults to
# 5173 if unset, which must match openimis-claimguard-module's
# CLAIMGUARD_BASE_URL (src/config.js in that repo). Change this one value
# if the port needs to move last-minute instead of editing vite.config.ts.
PORT="5173"

# openIMIS's GraphQL endpoint the dashboard's server-side client talks to
# (src/lib/openimis-client.server.ts). When the dashboard runs INSIDE Docker
# (docker-compose's claimguard-dash service) this is the internal hostname,
# http://backend:8000/api/graphql -- but when you run the dashboard directly
# on the host via `npm run dev` / scripts/dev-claimguard-fast.sh instead
# (recommended for fast iteration), the backend container only exists on
# localhost, so this must be http://localhost:8000/api/graphql.
OPENIMIS_GRAPHQL_URL="http://localhost:8000/api/graphql"

# openIMIS service account used by the dashboard's server-side GraphQL client
# (src/lib/openimis.server.ts) to fetch live claims from the local Docker
# stack's openIMIS backend. Use a working non-admin account (e.g. one of the
# demo dataset users) -- see README's "Known Limitations" for the Admin
# account login issue.
OPENIMIS_USERNAME=""
OPENIMIS_PASSWORD=""
