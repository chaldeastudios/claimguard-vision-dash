# Railway service: "db"
# Source: Docker Image -> ghcr.io/openimis/openimis-pgsql:develop
# Attach a Volume mounted at /var/lib/postgresql/data before first deploy.
# Do NOT expose a public domain/TCP proxy unless you need to run psql from
# your own machine to load demo-data/seed.sql -- enable it temporarily, then
# turn it back off.

POSTGRES_DB=openimis
POSTGRES_USER=postgres
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=<generate-a-strong-password>
DEMO_DATASET=true
