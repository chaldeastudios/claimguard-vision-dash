# Railway service: "frontend"
# Source: Docker Image -> ghcr.io/openimis/openimis-fe:develop
# No custom Dockerfile needed -- this image takes its config purely via env vars.

# Must be the BACKEND's PUBLIC domain (https), not its private/internal one --
# this URL gets baked into env-config.js and is called from the browser, which
# cannot reach *.railway.internal.
BACKEND_URL=https://${{backend.RAILWAY_PUBLIC_DOMAIN}}
PORT=80
OPENSEARCH_BASIC_TOKEN=dummy
