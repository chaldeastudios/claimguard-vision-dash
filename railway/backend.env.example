# Railway service: "backend"
# Source: this repo, Dockerfile Path = railway/backend.Dockerfile
# (NOT "deploy from public image" -- see railway/backend.Dockerfile for why)

DB_ENGINE=django.db.backends.postgresql
DB_NAME=openimis
DB_USER=postgres
# Must match POSTGRES_PASSWORD set on the "db" service.
DB_PASSWORD=<same-value-as-db-service-POSTGRES_PASSWORD>
# Reference the db service's private network address -- keeps DB traffic off
# the public internet and off your egress bill.
DB_HOST=${{db.RAILWAY_PRIVATE_DOMAIN}}
DB_PORT=5432

DEBUG=False
# Generate with: openssl rand -base64 48
SECRET_KEY=<generate-a-strong-secret-key>
# Railway's public domain for *this* service, e.g. openimis-backend-production.up.railway.app
# Add your custom domain too (comma-separated) once one is attached.
ALLOWED_HOSTS=${{RAILWAY_PUBLIC_DOMAIN}}
# Origins allowed to call this backend's GraphQL/API cross-origin.
# Must include the Vercel-hosted ClaimGuard dashboard domain.
CORS_ALLOWED_ORIGINS=https://claimguard.chaldeastudios.com

OPENIMIS_MODULES_CONFIG=/app/openimis.json

# --- Supabase sync (services.py _sync_to_supabase) ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
# IMPORTANT: this must be the service_role key, NOT the anon/publishable key.
# RLS only allows authenticated users to write (per CLAUDE.md), and this
# backend writes server-to-server with no authenticated browser session --
# the anon key will be silently rejected by RLS. Get this from
# Supabase Dashboard -> Project Settings -> API -> service_role.
# Never put this value in the frontend/dashboard env -- backend only.
SUPABASE_KEY=<service_role-key-not-anon-key>
